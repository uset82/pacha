NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=

# Preferred current Supabase browser key.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Legacy Supabase browser key. The app accepts this if no publishable key is set.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional server-only maintenance keys. Do not expose either in browser code.
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional until the owner confirms the real partner link.
NEXT_PUBLIC_FOODORA_URL=https://www.foodora.no/
