{
  "version": "1.0",
  "skills": [
    {
      "skillId": "framework-selector",
      "stage": "plan",
      "inputSchemaRef": ".antigravity/runtime/schemas/task-intent.schema.json",
      "outputSchemaRef": ".antigravity/runtime/schemas/stack-selection.schema.json",
      "emittedArtifacts": ["stack-selection", "decision-log"],
      "preconditions": ["TaskIntent is valid"],
      "postconditions": ["StackSelection is valid", "Decision log is appended to ArtifactManifest"]
    },
    {
      "skillId": "stitch-design",
      "stage": "design",
      "inputSchemaRef": ".antigravity/runtime/schemas/task-intent.schema.json",
      "outputSchemaRef": ".antigravity/runtime/schemas/artifact-manifest.schema.json",
      "emittedArtifacts": ["design-brief", "design-tokens", "component-inventory", "mood-board", "content-plan", "motion-plan", "stitch-html", "stitch-image"],
      "preconditions": ["TaskIntent exists", "StackSelection exists"],
      "postconditions": ["Portable design artifacts exist", "Frontend tasks include visual direction and narrative guidance when applicable", "Fallback artifacts exist when Stitch is unavailable"]
    },
    {
      "skillId": "project-scaffolder",
      "stage": "build",
      "inputSchemaRef": ".antigravity/runtime/schemas/stack-selection.schema.json",
      "outputSchemaRef": ".antigravity/runtime/schemas/artifact-manifest.schema.json",
      "emittedArtifacts": ["workspace-layout", "scaffold-log"],
      "preconditions": ["StackSelection is valid"],
      "postconditions": ["Generated workspace exists", "Scaffold log is recorded"]
    },
    {
      "skillId": "code-generator",
      "stage": "build",
      "inputSchemaRef": ".antigravity/runtime/schemas/artifact-manifest.schema.json",
      "outputSchemaRef": ".antigravity/runtime/schemas/artifact-manifest.schema.json",
      "emittedArtifacts": ["implementation-log", "file-map", "ui-verification-log"],
      "preconditions": ["Generated workspace exists", "Design artifacts exist"],
      "postconditions": ["Implementation log exists", "File map is recorded", "Rendered frontend work is verified when applicable"]
    },
    {
      "skillId": "security-audit",
      "stage": "security",
      "inputSchemaRef": ".antigravity/runtime/schemas/artifact-manifest.schema.json",
      "outputSchemaRef": ".antigravity/runtime/schemas/artifact-manifest.schema.json",
      "emittedArtifacts": ["security-threat-model", "validated-finding", "security-patch", "remediation-note"],
      "preconditions": ["Generated workspace exists", "Implementation log exists"],
      "postconditions": ["Threat model exists", "Validated findings are recorded"]
    },
    {
      "skillId": "deploy-advisor",
      "stage": "deploy",
      "inputSchemaRef": ".antigravity/runtime/schemas/stack-selection.schema.json",
      "outputSchemaRef": ".antigravity/runtime/schemas/artifact-manifest.schema.json",
      "emittedArtifacts": ["deploy-config", "deploy-instructions"],
      "preconditions": ["StackSelection is valid", "Generated workspace path exists"],
      "postconditions": ["Deploy config exists", "Instructions are recorded"]
    }
  ]
}
